@prefix hpo:  <http://kg.example.com/harrypotter-oop/ontology/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:   <http://purl.org/dc/elements/1.1/> .

hpo:HarryPotterOoPOntology a owl:Ontology ;
    dc:title "哈利·波特与凤凰社知识图谱本体"@zh ;
    dc:description "基于《哈利·波特与凤凰社》全文的人物关系知识图谱本体。6类顶层实体（人物/组织/地点/物品/事件/作品），33个二级子类，16类对象属性，16个数据属性（v1.3 修复了 30→16 的数据属性膨胀问题，补全 alias 定义、加 domain 限制、删重复与未用属性）。"@zh ;
    owl:versionInfo "1.3" .

# ============================================================
# 顶层类（6 大类）
# ============================================================

hpo:Person a owl:Class ;
    rdfs:label "人物"@zh ;
    rdfs:comment "凤凰社知识图谱中的人物实体，含巫师/麻瓜/家养小精灵/马人/巨人/鬼魂等子类"@zh .

hpo:Organization a owl:Class ;
    rdfs:label "组织"@zh ;
    rdfs:comment "凤凰社知识图谱中的组织实体，含学校/学院/犯罪组织/魔法机构/社团等子类"@zh .

hpo:Place a owl:Class ;
    rdfs:label "地点"@zh ;
    rdfs:comment "凤凰社知识图谱中的地点实体，含住宅/学校建筑/公共场所/魔法地点等子类"@zh .

hpo:Item a owl:Class ;
    rdfs:label "物品"@zh ;
    rdfs:comment "凤凰社知识图谱中的物品实体，含信物/魔法器物/门钥匙/其他等子类"@zh .

hpo:Event a owl:Class ;
    rdfs:label "事件"@zh ;
    rdfs:comment "凤凰社知识图谱中的事件实体，含战斗/审判/集会/考试/袭击/其他事件等子类"@zh .

hpo:Work a owl:Class ;
    rdfs:label "作品"@zh ;
    rdfs:comment "凤凰社知识图谱中的作品实体，含书籍/教科书/刊物/报道/信件/传单/其他作品等子类"@zh .

# ============================================================
# 人物子类（7 个）
# ============================================================

hpo:Wizard a owl:Class ;
    rdfs:subClassOf hpo:Person ;
    rdfs:label "巫师"@zh ;
    rdfs:comment "具有魔法能力的人物，包括纯血、混血、麻瓜出身"@zh .

hpo:Muggle a owl:Class ;
    rdfs:subClassOf hpo:Person ;
    rdfs:label "麻瓜"@zh ;
    rdfs:comment "没有魔法能力的普通人类"@zh .

hpo:HouseElf a owl:Class ;
    rdfs:subClassOf hpo:Person ;
    rdfs:label "家养小精灵"@zh ;
    rdfs:comment "魔法界特有的魔法生物，世代服务于巫师家族"@zh .

hpo:Centaur a owl:Class ;
    rdfs:subClassOf hpo:Person ;
    rdfs:label "马人"@zh ;
    rdfs:comment "上半身为人、下半身为马的魔法生物"@zh .

hpo:Giant a owl:Class ;
    rdfs:subClassOf hpo:Person ;
    rdfs:label "巨人"@zh ;
    rdfs:comment "体型巨大的魔法生物"@zh .

hpo:Ghost a owl:Class ;
    rdfs:subClassOf hpo:Person ;
    rdfs:label "鬼魂"@zh ;
    rdfs:comment "人类死亡后留下的灵魂形态"@zh .

hpo:OtherMagicalCreature a owl:Class ;
    rdfs:subClassOf hpo:Person ;
    rdfs:label "其他魔法生物"@zh ;
    rdfs:comment "其他无法归入上述子类的人物型魔法生物"@zh .

# ============================================================
# 组织子类（5 个）
# ============================================================

hpo:School a owl:Class ;
    rdfs:subClassOf hpo:Organization ;
    rdfs:label "学校"@zh ;
    rdfs:comment "魔法教育机构，如霍格沃茨"@zh .

hpo:Academy a owl:Class ;
    rdfs:subClassOf hpo:Organization ;
    rdfs:label "学院"@zh ;
    rdfs:comment "学校内的分院组织，如格兰芬多、斯莱特林"@zh .

hpo:CriminalOrganization a owl:Class ;
    rdfs:subClassOf hpo:Organization ;
    rdfs:label "犯罪组织"@zh ;
    rdfs:comment "以犯罪为目的的组织，如食死徒、阿兹卡班"@zh .

hpo:MagicalInstitution a owl:Class ;
    rdfs:subClassOf hpo:Organization ;
    rdfs:label "魔法机构"@zh ;
    rdfs:comment "魔法部、傲罗办公室、圣芒戈等政府或公共服务机构"@zh .

hpo:Club a owl:Class ;
    rdfs:subClassOf hpo:Organization ;
    rdfs:label "社团"@zh ;
    rdfs:comment "以共同目标或兴趣组成的非正式团体，如凤凰社、邓布利多军"@zh .

# ============================================================
# 地点子类（4 个，原 House 重命名为 Place）
# ============================================================

hpo:Residence a owl:Class ;
    rdfs:subClassOf hpo:Place ;
    rdfs:label "住宅"@zh ;
    rdfs:comment "人物居住的房屋，如陋居、格里莫广场12号、女贞路4号"@zh .

hpo:BuildingInSchool a owl:Class ;
    rdfs:subClassOf hpo:Place ;
    rdfs:label "学校建筑"@zh ;
    rdfs:comment "霍格沃茨内的建筑与场所，如霍格沃茨城堡、格兰芬多公共休息室、邓布利多办公室"@zh .

hpo:PublicPlace a owl:Class ;
    rdfs:subClassOf hpo:Place ;
    rdfs:label "公共场所"@zh ;
    rdfs:comment "面向公众开放或服务于大众的场所，如对角巷、霍格莫德村、车站"@zh .

hpo:MagicalLocation a owl:Class ;
    rdfs:subClassOf hpo:Place ;
    rdfs:label "魔法地点"@zh ;
    rdfs:comment "具有特殊魔法属性或仅存在于魔法世界的地点，如禁林、神秘事务司、有求必应屋"@zh .

# ============================================================
# 物品子类（6 个）
# ============================================================

hpo:Token a owl:Class ;
    rdfs:subClassOf hpo:Item ;
    rdfs:label "信物"@zh ;
    rdfs:comment "具有重要象征意义或纪念价值的物品"@zh .

hpo:MagicalArtifact a owl:Class ;
    rdfs:subClassOf hpo:Item ;
    rdfs:label "魔法器物"@zh ;
    rdfs:comment "具有魔法功能的器物，如预言球、隐形衣、守护神"@zh .

hpo:Portkey a owl:Class ;
    rdfs:subClassOf hpo:Item ;
    rdfs:label "门钥匙"@zh ;
    rdfs:comment "用于空间瞬移的魔法物品"@zh .

hpo:Wand a owl:Class ;
    rdfs:subClassOf hpo:Item ;
    rdfs:label "魔杖"@zh ;
    rdfs:comment "巫师施放魔法的工具（凤凰社卷未抽出具体魔杖实例）"@zh .

hpo:Potion a owl:Class ;
    rdfs:subClassOf hpo:Item ;
    rdfs:label "药水"@zh ;
    rdfs:comment "具有特定魔药效果的液体（凤凰社卷未抽出具体药水实例）"@zh .

hpo:Weapon a owl:Class ;
    rdfs:subClassOf hpo:Item ;
    rdfs:label "武器"@zh ;
    rdfs:comment "用于攻击或防御的武器"@zh .

hpo:OtherItem a owl:Class ;
    rdfs:subClassOf hpo:Item ;
    rdfs:label "其他物品"@zh ;
    rdfs:comment "无法归入上述子类的物品，如宠物（海德薇）、饮料（黄油啤酒）、棋类"@zh .

# ============================================================
# 事件子类（6 个）
# ============================================================

hpo:Battle a owl:Class ;
    rdfs:subClassOf hpo:Event ;
    rdfs:label "战斗"@zh ;
    rdfs:comment "涉及冲突或武力的对抗事件"@zh .

hpo:Trial a owl:Class ;
    rdfs:subClassOf hpo:Event ;
    rdfs:label "审判"@zh ;
    rdfs:comment "威森加摩等机构的司法审判事件"@zh .

hpo:Gathering a owl:Class ;
    rdfs:subClassOf hpo:Event ;
    rdfs:label "集会"@zh ;
    rdfs:comment "多人聚集的社交或会议事件"@zh .

hpo:Examination a owl:Class ;
    rdfs:subClassOf hpo:Event ;
    rdfs:label "考试"@zh ;
    rdfs:comment "O.W.L.、N.E.W.T.等学术考试事件"@zh .

hpo:Attack a owl:Class ;
    rdfs:subClassOf hpo:Event ;
    rdfs:label "袭击"@zh ;
    rdfs:comment "针对个人或机构的突然攻击事件"@zh .

hpo:OtherEvent a owl:Class ;
    rdfs:subClassOf hpo:Event ;
    rdfs:label "其他事件"@zh ;
    rdfs:comment "无法归入上述子类的事件，如教育令颁布、人物任命/解雇"@zh .

# ============================================================
# 作品子类（7 个）
# ============================================================

hpo:Book a owl:Class ;
    rdfs:subClassOf hpo:Work ;
    rdfs:label "书籍"@zh ;
    rdfs:comment "成册的书籍类作品"@zh .

hpo:Textbook a owl:Class ;
    rdfs:subClassOf hpo:Work ;
    rdfs:label "教科书"@zh ;
    rdfs:comment "用于教学的教科书"@zh .

hpo:Periodical a owl:Class ;
    rdfs:subClassOf hpo:Work ;
    rdfs:label "刊物"@zh ;
    rdfs:comment "定期发行的刊物，如预言家日报、唱唱反调"@zh .

hpo:Report a owl:Class ;
    rdfs:subClassOf hpo:Work ;
    rdfs:label "报道"@zh ;
    rdfs:comment "新闻报道或专访，如《独家采访哈利·波特》"@zh .

hpo:Letter a owl:Class ;
    rdfs:subClassOf hpo:Work ;
    rdfs:label "信件"@zh ;
    rdfs:comment "书信类作品（凤凰社卷未抽出信件实例）"@zh .

hpo:Flyer a owl:Class ;
    rdfs:subClassOf hpo:Work ;
    rdfs:label "传单"@zh ;
    rdfs:comment "宣传或通告类单页作品（凤凰社卷未抽出传单实例）"@zh .

hpo:OtherWork a owl:Class ;
    rdfs:subClassOf hpo:Work ;
    rdfs:label "其他作品"@zh ;
    rdfs:comment "无法归入上述子类的作品，如教育令、法律文本、官方文件"@zh .

# ============================================================
# 对象属性（关系）—— 顶层 16 类
# ============================================================

hpo:hasFamilyRelation a owl:ObjectProperty ;
    rdfs:label "亲属关系"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Person .

hpo:hasMentorRelation a owl:ObjectProperty ;
    rdfs:label "师生关系"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Person .

hpo:hasFriendRelation a owl:ObjectProperty ;
    rdfs:label "朋友关系"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Person .

hpo:hasEnemyRelation a owl:ObjectProperty ;
    rdfs:label "敌对关系"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Organization .

hpo:hasLoveRelation a owl:ObjectProperty ;
    rdfs:label "恋人关系"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Person .

hpo:memberOf a owl:ObjectProperty ;
    rdfs:label "组织成员"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Organization .

hpo:leads a owl:ObjectProperty ;
    rdfs:label "领导"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Organization .

hpo:opposes a owl:ObjectProperty ;
    rdfs:label "对抗"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Organization .

hpo:supports a owl:ObjectProperty ;
    rdfs:label "支持"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Organization .

hpo:controls a owl:ObjectProperty ;
    rdfs:label "管控"@zh ;
    rdfs:domain hpo:Organization ;
    rdfs:range hpo:Organization .

hpo:livesIn a owl:ObjectProperty ;
    rdfs:label "居住"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Place .

hpo:visits a owl:ObjectProperty ;
    rdfs:label "造访"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Place .

hpo:owns a owl:ObjectProperty ;
    rdfs:label "拥有"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Item .

hpo:uses a owl:ObjectProperty ;
    rdfs:label "使用"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Item .

hpo:participatesIn a owl:ObjectProperty ;
    rdfs:label "参与"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range hpo:Event .

hpo:precedes a owl:ObjectProperty ;
    rdfs:label "发生于…之前"@zh ;
    rdfs:domain hpo:Event ;
    rdfs:range hpo:Event .

hpo:leadsTo a owl:ObjectProperty ;
    rdfs:label "导致"@zh ;
    rdfs:domain hpo:Event ;
    rdfs:range hpo:Event .

# 对象属性的子属性
hpo:isParentOf a owl:ObjectProperty ;
    rdfs:label "是…的父母"@zh ;
    rdfs:subPropertyOf hpo:hasFamilyRelation .

hpo:isChildOf a owl:ObjectProperty ;
    rdfs:label "是…的子女"@zh ;
    rdfs:subPropertyOf hpo:hasFamilyRelation .

hpo:isSiblingOf a owl:ObjectProperty ;
    rdfs:label "是…的兄弟姐妹"@zh ;
    rdfs:subPropertyOf hpo:hasFamilyRelation .

hpo:isUncleAuntOf a owl:ObjectProperty ;
    rdfs:label "是…的叔伯/阿姨"@zh ;
    rdfs:subPropertyOf hpo:hasFamilyRelation .

hpo:isCousinOf a owl:ObjectProperty ;
    rdfs:label "是…的表亲"@zh ;
    rdfs:subPropertyOf hpo:hasFamilyRelation .

hpo:isGodfatherOf a owl:ObjectProperty ;
    rdfs:label "是…的教父"@zh ;
    rdfs:subPropertyOf hpo:hasFamilyRelation .

hpo:teaches a owl:ObjectProperty ;
    rdfs:label "教授"@zh ;
    rdfs:subPropertyOf hpo:hasMentorRelation .

hpo:trainedBy a owl:ObjectProperty ;
    rdfs:label "受训于"@zh ;
    rdfs:subPropertyOf hpo:hasMentorRelation .

hpo:isHeadOf a owl:ObjectProperty ;
    rdfs:label "是…的负责人"@zh ;
    rdfs:subPropertyOf hpo:hasMentorRelation .

hpo:studiesAt a owl:ObjectProperty ;
    rdfs:label "就读于"@zh ;
    rdfs:subPropertyOf hpo:hasMentorRelation .

hpo:fightsFor a owl:ObjectProperty ;
    rdfs:label "为…战斗"@zh ;
    rdfs:subPropertyOf hpo:memberOf .

hpo:worksFor a owl:ObjectProperty ;
    rdfs:label "为…工作"@zh ;
    rdfs:subPropertyOf hpo:memberOf .

hpo:hasKeyRole a owl:ObjectProperty ;
    rdfs:label "在…中担任关键角色"@zh ;
    rdfs:subPropertyOf hpo:memberOf .

hpo:hasHome a owl:ObjectProperty ;
    rdfs:label "家在"@zh ;
    rdfs:subPropertyOf hpo:livesIn .

hpo:hasSchoolDorm a owl:ObjectProperty ;
    rdfs:label "学校宿舍在"@zh ;
    rdfs:subPropertyOf hpo:livesIn .

hpo:hasWorkResidence a owl:ObjectProperty ;
    rdfs:label "工作住所"@zh ;
    rdfs:subPropertyOf hpo:livesIn .

hpo:ownsPet a owl:ObjectProperty ;
    rdfs:label "拥有宠物"@zh ;
    rdfs:subPropertyOf hpo:owns .

hpo:ownsHeirloom a owl:ObjectProperty ;
    rdfs:label "拥有传家宝"@zh ;
    rdfs:subPropertyOf hpo:owns .

hpo:ownsBroom a owl:ObjectProperty ;
    rdfs:label "拥有飞天扫帚"@zh ;
    rdfs:subPropertyOf hpo:owns .

hpo:ownsToy a owl:ObjectProperty ;
    rdfs:label "拥有玩具"@zh ;
    rdfs:subPropertyOf hpo:owns .

hpo:usesMagic a owl:ObjectProperty ;
    rdfs:label "使用魔法器物"@zh ;
    rdfs:subPropertyOf hpo:uses .

hpo:usesDrink a owl:ObjectProperty ;
    rdfs:label "饮用"@zh ;
    rdfs:subPropertyOf hpo:uses .

hpo:inPainting a owl:ObjectProperty ;
    rdfs:label "画中人居住在"@zh ;
    rdfs:subPropertyOf hpo:livesIn .

hpo:isNeighborOf a owl:ObjectProperty ;
    rdfs:label "是…的邻居"@zh ;
    rdfs:subPropertyOf hpo:hasFamilyRelation .

hpo:hasTemporaryRelation a owl:ObjectProperty ;
    rdfs:label "临时关系"@zh .

# ============================================================
# 数据属性（v1.3 修复）
#
# 修复说明（v1.2 → v1.3）：
#   1. 补上 hpo:alias 定义（实例用了 205 次，原 v1.2 本体漏定义）
#   2. 给所有数据属性加 rdfs:domain（v1.2 全缺失，破坏本体约束）
#   3. 删除重复属性：hasConfidence / hasVoteCount / isKnownPair /
#      isFromPrior / hasChapter / hasChapterEnd（语义与 confidence /
#      nVotes / isPriorPair / firstAppearChapter 等重叠）
#   4. 删除错误属性 hasObject（自称 blank node 内但 range 标 anyURI，
#      自相矛盾，实际不应作为数据属性存在）
#   5. 删除 8 个定义但实例未使用的过度细化属性：
#      eventType / keyParticipant / itemType / workType /
#      contentSummary / placeType / location / occurPlace
#   6. 保留 4 个跨卷可能复用的核心预留属性（命名规范、语义独立）：
#      wandMaterial / patronus / status / leader
#   7. 给所有数据属性加 rdfs:comment
#   8. 关系元数据属性（confidence/nVotes/isPriorPair/evidenceChapter）
#      通过 blank node 挂到三元组实例上（不直接挂在实体上）
#
# 数量：30 → 16（精简 47%）
# 实体核心属性 7 + 实体预留属性 4 + 关系元数据属性 4 + 通用统计属性 1 = 16
# （chapterCount / firstAppearChapter 属于通用统计，对所有顶层类适用）
# ============================================================

# ---------- 人物属性（7 个，核心 5 + 预留 2）----------

hpo:alias a owl:DatatypeProperty ;
    rdfs:label "别名"@zh ;
    rdfs:comment "人物或实体的其他称呼、中文昵称、英文原名等。同一个实例可有多个 alias。"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range xsd:string .

hpo:house a owl:DatatypeProperty ;
    rdfs:label "所属学院"@zh ;
    rdfs:comment "霍格沃茨四学院之一：格兰芬多 / 斯莱特林 / 拉文克劳 / 赫奇帕奇。仅巫师实例使用。"@zh ;
    rdfs:domain hpo:Wizard ;
    rdfs:range xsd:string .

hpo:bloodStatus a owl:DatatypeProperty ;
    rdfs:label "血统"@zh ;
    rdfs:comment "巫师血统：纯血 / 混血 / 麻瓜出身。仅巫师实例使用。"@zh ;
    rdfs:domain hpo:Wizard ;
    rdfs:range xsd:string .

hpo:identity a owl:DatatypeProperty ;
    rdfs:label "身份/职业"@zh ;
    rdfs:comment "人物在社会中的角色，如学生、教师、记者、傲罗、食死徒、店主等。仅巫师实例使用。"@zh ;
    rdfs:domain hpo:Wizard ;
    rdfs:range xsd:string .

hpo:isOrderMember a owl:DatatypeProperty ;
    rdfs:label "是否凤凰社成员"@zh ;
    rdfs:comment "布尔值，标识该人物是否为凤凰社成员。仅巫师实例使用。"@zh ;
    rdfs:domain hpo:Wizard ;
    rdfs:range xsd:boolean .

hpo:wandMaterial a owl:DatatypeProperty ;
    rdfs:label "魔杖材质"@zh ;
    rdfs:comment "巫师魔杖的核心材质（如凤凰羽毛、独角兽尾毛、龙心腱等）。凤凰社卷未抽出具体实例，预留给后续卷。"@zh ;
    rdfs:domain hpo:Wizard ;
    rdfs:range xsd:string .

hpo:patronus a owl:DatatypeProperty ;
    rdfs:label "守护神形态"@zh ;
    rdfs:comment "巫师的守护神咒所呈现的具体动物形态（如牡鹿、牝猫、水獭等）。凤凰社卷未抽出具体实例，预留给后续卷。"@zh ;
    rdfs:domain hpo:Wizard ;
    rdfs:range xsd:string .

# ---------- 组织属性（1 个，预留）----------

hpo:leader a owl:DatatypeProperty ;
    rdfs:label "领导者"@zh ;
    rdfs:comment "组织的核心领导者姓名（凤凰社为邓布利多，食死徒为伏地魔，DA 为哈利）。凤凰社卷未抽出具体实例，预留给后续卷。"@zh ;
    rdfs:domain hpo:Organization ;
    rdfs:range xsd:string .

# ---------- 通用统计属性（2 个，所有顶层类共有）----------

hpo:status a owl:DatatypeProperty ;
    rdfs:label "生死/活跃状态"@zh ;
    rdfs:comment "实体在小说当前卷中的状态：alive（存活）/ dead（已故）/ active（活跃）/ defunct（已解散）等。凤凰社卷未抽出具体实例，预留给后续卷。"@zh ;
    rdfs:domain hpo:Person ;
    rdfs:range xsd:string .

hpo:chapterCount a owl:DatatypeProperty ;
    rdfs:label "出现章节数"@zh ;
    rdfs:comment "该实体在原文中出现的章节数（去重后的统计值）。设计为可挂在任何 owl:Thing 上，实例中所有顶层类（人物/组织/地点/物品/事件/作品）共用。"@zh ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:integer .

hpo:firstAppearChapter a owl:DatatypeProperty ;
    rdfs:label "首次出场章节"@zh ;
    rdfs:comment "该实体在原文中首次被提及的章节号（1-38）。设计为可挂在任何 owl:Thing 上，实例中所有顶层类共用。"@zh ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:integer .

# ---------- 关系元数据属性（4 个，挂在三元组 blank node 上）----------
#
# 这些属性描述三元组（关系事实）本身的可信度，不描述实体特征。
# 在 RDF 中通过 blank node 挂到关系实例上，例如：
#   hpo:哈利_波特 hpo:isParentOf [
#       hpo:target hpo:詹姆_波特 ;
#       hpo:confidence "0.95"^^xsd:double ;
#       hpo:nVotes "3"^^xsd:integer ;
#       hpo:isPriorPair "true"^^xsd:boolean ;
#       hpo:evidenceChapter "5"^^xsd:integer
#   ] .

hpo:confidence a owl:DatatypeProperty ;
    rdfs:label "置信度"@zh ;
    rdfs:comment "三元组（关系事实）的抽取置信度，0~1 之间。三模型投票后归一化得分。设计为挂在关系 blank node 上（domain 设为 owl:Thing 兼容）。"@zh ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:double .

hpo:nVotes a owl:DatatypeProperty ;
    rdfs:label "模型投票数"@zh ;
    rdfs:comment "支持该三元组（关系事实）的模型数量（1-3）。实体侧 3 模型并行 + 投票；1 表示仅一个模型支持。挂在关系 blank node 上。"@zh ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:integer .

hpo:isPriorPair a owl:DatatypeProperty ;
    rdfs:label "是否先验种子对"@zh ;
    rdfs:comment "布尔值，标识该关系是否来自先验种子表（如凤凰社首批成员-邓布利多、食死徒-伏地魔等强先验对）。挂在关系 blank node 上。"@zh ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:boolean .

hpo:evidenceChapter a owl:DatatypeProperty ;
    rdfs:label "证据章节"@zh ;
    rdfs:comment "三元组（关系事实）的关键证据所在章节号。挂在关系 blank node 上。"@zh ;
    rdfs:domain owl:Thing ;
    rdfs:range xsd:integer .


@prefix hp:   <http://kg.example.com/harrypotter-oop/entity/> .
@prefix hpo:  <http://kg.example.com/harrypotter-oop/ontology/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

